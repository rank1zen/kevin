KEVIN_ENV=development           # development | staging | production
KEVIN_PORT=3000
KEVIN_HOST=0.0.0.0
KEVIN_PUBLIC_BASE_URL=http://localhost:3000
KEVIN_LOG_LEVEL=info            # debug | info | warn | error

# Database (Postgres)
KEVIN_DB_HOST=localhost
KEVIN_DB_PORT=5432
KEVIN_DB_NAME=kevin
KEVIN_DB_USER=kevin
KEVIN_DB_PASSWORD=change-me
KEVIN_DB_SSL_MODE=disable       # disable | require | verify-ca | verify-full
KEVIN_DB_POOL_MAX=20
KEVIN_DB_POOL_MIN=2
KEVIN_DB_CONNECT_TIMEOUT_MS=5000

# Optional: single URL form (some libs prefer this)
KEVIN_DATABASE_URL=postgres://kevin:change-me@localhost:5432/kevin?sslmode=disable

# Tern Migrator
TERN_CONFIG=./tern.conf
TERN_MIGRATIONS=./migrations

# Health / diagnostics
KEVIN_HEALTHCHECK_PATH=/healthz
KEVIN_READYCHECK_PATH=/readyz
