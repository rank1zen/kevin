package rank_card_loader

import "context"

type RankCardLoaderData struct {
	PUUID  string
	Region string
}

templ RankCardLoader(ctx context.Context, data RankCardLoaderData) {
	<div
		hx-get="/partial/rank_card.RankCard"
		hx-trigger="load once"
	>
		<div class="h-40 animate-pulse border shadow-sm shadow-gray-200 rounded-default bg-neutral-secondary border-default"></div>
	</div>
}
